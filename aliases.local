# Git
alias gs='git status '
alias ga='git add '
alias gb='git branch '
alias gc='git commit'
alias gd='git diff'
alias gp='git push'
alias gco='git checkout '

# Tmux
alias tr='~/.bin/tmux-resurrect-auto-rename'
alias ta='tmux attach -t'
alias ts='tmux new-session -s'
alias tl='tmux list-sessions'

# Misc
alias c='clear'
